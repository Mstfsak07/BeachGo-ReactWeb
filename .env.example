# ─── Veritabanı (PostgreSQL) ─────────────────────────────
DB_PASSWORD=SecretPassword123!

# ─── Redis ───────────────────────────────────────────────
REDIS_PASSWORD=RedisSecret123!

# ─── JWT Secret (min. 32 karakter — üretimde mutlaka değiştirin!) ──
BEACHGO_JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters!!

# ─── CORS ────────────────────────────────────────────────
BEACHGO_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ─── Stripe (boş bırakılırsa mock mod aktif olur) ────────
STRIPE_SECRET_KEY=sk_test_your_stripe_key_here

# ─── ASP.NET Core ────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Development

# ─── Frontend ────────────────────────────────────────────
REACT_APP_API_URL=http://localhost:5143/api
VITE_API_URL=http://localhost:5143/api

# ─── E-posta / Resend ─────────────────────────────────────
# Bu key varsa development dahil gerçek mail gönderilir.
# resend.com'dan alınan API key'i buraya girin.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Frontend URL (doğrulama mailindeki link bu URL'yi kullanır)
APP_URL=http://localhost:3000

# Admin kullanıcı başlangıç şifresi (seed için zorunlu)
ADMIN_PASSWORD=
