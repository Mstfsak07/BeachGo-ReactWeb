# ─── Veritabanı (PostgreSQL) ─────────────────────────────
DB_PASSWORD=SecretPassword123!

# ─── Redis ───────────────────────────────────────────────
REDIS_PASSWORD=RedisSecret123!

# ─── JWT Secret (min. 32 karakter — üretimde mutlaka değiştirin!) ──
BEACHGO_JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters!!

# ─── CORS ────────────────────────────────────────────────
BEACHGO_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ─── Stripe (boş bırakılırsa mock mod aktif olur) ────────
STRIPE_SECRET_KEY=sk_test_your_stripe_key_here

# ─── ASP.NET Core ────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Development

# ─── Frontend ────────────────────────────────────────────
REACT_APP_API_URL=http://localhost:5143
VITE_API_URL=http://localhost:5143

